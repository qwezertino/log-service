# OpenObserve admin credentials
ZO_ROOT_USER_EMAIL=admin@example.com
ZO_ROOT_USER_PASSWORD=changeme123

# MinIO — full URL including port (http or https)
# Use host.docker.internal so the OpenObserve container can reach the host
MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=geopassword

# Bucket that OpenObserve will use for log storage
OO_BUCKET=openobserve-logs

# OpenObserve storage mode — do not change unless you know what you're doing
# ZO_LOCAL_MODE=true keeps single-node mode (SQLite for metadata)
# ZO_LOCAL_MODE_STORAGE=s3 routes parquet data to S3 instead of local disk
ZO_LOCAL_MODE=true
ZO_LOCAL_MODE_STORAGE=s3
ZO_S3_PROVIDER=minio
ZO_S3_REGION_NAME=us-east-1

# Port to expose OpenObserve UI (default 5080)
HOST_PORT_OO=5080

# Log retention in days (default 90 = 3 months)
LOG_RETENTION_DAYS=90

# Tuning — how fast WAL data is flushed and pushed to S3
ZO_COMPACT_INTERVAL=1         # compaction interval in minutes (default: 10)
ZO_FILE_PUSH_INTERVAL=5       # WAL push job trigger interval in seconds (default: 10)
ZO_MAX_FILE_RETENTION_TIME=60 # max seconds before WAL file is closed and pushed (default: 600)
ZO_MEM_PERSIST_INTERVAL=2     # memory-to-disk flush interval in seconds (default: 2)
