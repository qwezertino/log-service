# OpenObserve admin credentials
ZO_ROOT_USER_EMAIL=admin@example.com
ZO_ROOT_USER_PASSWORD=changeme123

# MinIO — full URL including port (http or https)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=geopassword

# Bucket that OpenObserve will use for log storage (created automatically)
OO_BUCKET=openobserve-logs

# Port to expose OpenObserve UI (default 5080)
HOST_PORT_OO=5080

# Log retention in days (default 90 = 3 months)
LOG_RETENTION_DAYS=90
